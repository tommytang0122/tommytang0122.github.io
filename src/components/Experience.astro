---
const items = [
  {
    date: '2022/09 – 2022/12',
    company: 'DigiPen Institute of Technology',
    role: 'Teaching Assistant',
    bullets: [] as string[],
  },
  {
    date: '2019/10 – 2020/05',
    company: 'Rayark Inc.',
    role: 'Quality Assurance Analyst',
    bullets: [] as string[],
  },
  {
    date: '2018/10 – 2019/05',
    company: 'So-Cayenne Entertainment',
    role: 'Unity Software Engineer',
    bullets: [] as string[],
  },
];
---

<section id="experience" class="bg-[var(--color-bg-alt)] py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="heading reveal">Experience</h2>

    <ol class="relative mt-12 border-l border-[var(--color-border)] pl-8">
      {
        items.map((it) => (
          <li class="reveal mb-12 last:mb-0 relative">
            <span class="absolute -left-[37px] flex h-4 w-4 items-center justify-center rounded-full bg-[var(--color-base)] ring-4 ring-[var(--color-bg-alt)]"></span>
            <time class="text-sm uppercase tracking-[0.15em] text-[var(--color-muted)]">
              {it.date}
            </time>
            <h3 class="mt-1 text-xl md:text-2xl">{it.company}</h3>
            <p class="mt-1 text-[var(--color-base)] font-medium uppercase tracking-wide text-sm">
              {it.role}
            </p>
            {it.bullets.length > 0 && (
              <ul class="mt-3 list-disc space-y-1 pl-5 text-[var(--color-text)]">
                {it.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</section>
