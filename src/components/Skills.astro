---
const groups = [
  {
    title: 'Languages',
    items: ['C', 'C++', 'C#', 'GLSL', 'TypeScript'],
  },
  {
    title: 'Engines & Graphics',
    items: ['Unity', 'Unreal', 'OpenGL', 'Custom Engine', 'ImGUI'],
  },
  {
    title: 'Computer Science',
    items: ['Data Structures', 'Algorithms', 'Design Patterns', '3D Math', 'Game AI'],
  },
  {
    title: 'Tools',
    items: ['Git', 'Perforce', 'SVN', 'WSL', 'Notion', 'Slack'],
  },
];
---

<section id="skills" class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="heading reveal">Skills</h2>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {
        groups.map((g) => (
          <div class="reveal rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
            <h3 class="text-sm uppercase tracking-[0.2em] text-[var(--color-base)]">
              {g.title}
            </h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {g.items.map((s) => (
                <li class="rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-1 text-sm">
                  {s}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
