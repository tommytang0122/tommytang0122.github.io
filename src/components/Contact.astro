---
const email = 'tommytang0122@gmail.com';
const emailDigipen = 'tommy.tang@digipen.edu';
const phone = '+1 425-614-9579';

const socials = [
  { label: 'GitHub', href: 'https://github.com/pokemonslimit' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/che-tang-aba848207/' },
  { label: 'Facebook', href: 'https://www.facebook.com/che.tang.39' },
];
---

<section id="contact" class="bg-[var(--color-bg-alt)] py-24">
  <div class="mx-auto max-w-6xl px-6 text-center">
    <h2 class="heading reveal mx-auto">Contact</h2>
    <div class="reveal mt-6 space-y-2 text-lg">
      <p>
        <a href={`mailto:${email}`} class="hover:text-[var(--color-base)]">{email}</a>
      </p>
      <p>
        <a href={`mailto:${emailDigipen}`} class="hover:text-[var(--color-base)]">{emailDigipen}</a>
      </p>
      <p class="text-[var(--color-muted)]">{phone}</p>
    </div>
    <ul class="reveal mt-10 flex items-center justify-center gap-5 text-sm uppercase tracking-[0.2em]">
      {
        socials.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              class="text-[var(--color-muted)] transition hover:text-[var(--color-base)]"
            >
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<footer class="border-t border-[var(--color-border)] py-8 text-center text-sm text-[var(--color-muted)]">
  &copy; {new Date().getFullYear()} Tommy Tang
</footer>
