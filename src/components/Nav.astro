---
const links = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#education', label: 'Education' },
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Skills' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent bg-[var(--color-bg)]/0 backdrop-blur transition-[background-color,border-color] duration-300"
  id="site-nav"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="#top" class="text-lg font-bold tracking-wide text-[var(--color-heading)]">
      Tommy Tang
    </a>
    <button
      id="nav-toggle"
      class="md:hidden text-[var(--color-heading)]"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <ul id="nav-menu" class="hidden md:flex items-center gap-7 text-sm font-medium tracking-wide uppercase">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-[var(--color-text)] transition hover:text-[var(--color-base)]"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <ul
    id="nav-menu-mobile"
    class="hidden flex-col gap-4 border-t border-[var(--color-border)] bg-[var(--color-bg)] px-6 py-5 text-sm uppercase tracking-wide md:hidden"
  >
    {
      links.map((l) => (
        <li>
          <a
            href={l.href}
            class="block text-[var(--color-text)] transition hover:text-[var(--color-base)]"
          >
            {l.label}
          </a>
        </li>
      ))
    }
  </ul>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('nav-menu-mobile');

  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 40) {
      nav.classList.add('!bg-[var(--color-bg)]/85', 'border-[var(--color-border)]');
    } else {
      nav.classList.remove('!bg-[var(--color-bg)]/85', 'border-[var(--color-border)]');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  toggle?.addEventListener('click', () => {
    mobile?.classList.toggle('hidden');
    mobile?.classList.toggle('flex');
  });
  mobile?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      mobile.classList.add('hidden');
      mobile.classList.remove('flex');
    }),
  );
</script>
